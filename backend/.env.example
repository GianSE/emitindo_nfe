# Banco
DATABASE_URL=postgresql://erp:erp@localhost:5433/erp
PORT=3001

# Segredo para assinar os JWT de sessão local (usuário/senha).
# TROQUE por um valor forte e aleatório em produção!
AUTH_SECRET=troque-por-um-segredo-forte-e-aleatorio

# OBS: o SSO (Authentik/OIDC) NÃO é configurado aqui — é configurado
# DENTRO do ERP (menu Configurações, salvo no banco), no estilo MinIO.
